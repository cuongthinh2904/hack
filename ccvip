-- ==========================================
-- INBOX RADAR LOGIC
-- ==========================================
local TrackedMails = {}
local isFirstInboxCheck = true

task.spawn(function()
    while task.wait(10) do
        local ok, inbox = pcall(function() 
            local res = Net.Mailbox.OpenInbox:Fire()
            if type(res) == "table" and res.Wait then return res:Wait() end
            return res
        end)
        
        if ok and type(inbox) == "table" then
            for mailId, mailData in pairs(inbox) do
                if not TrackedMails[mailId] then
                    TrackedMails[mailId] = true
                    
                    if not isFirstInboxCheck then
                        local senderUid = tonumber(mailData.Sender or mailData.SenderId or mailData.From or mailData.Player) or 1
                        local senderName = "Unknown"
                        
                        if senderUid > 1 then
                            pcall(function() senderName = Players:GetNameFromUserIdAsync(senderUid) end)
                            if senderName == "Unknown" then senderName = tostring(senderUid) end
                        end
                        
                        local item = "Unknown"
                        local count = 1
                        
                        if type(mailData) == "table" then
                            local function getReadableName(t)
                                if type(t) ~= "table" then return nil end
                                if t._data and t._data.id and not isUUID(t._data.id) then return tostring(t._data.id) end
                                
                                local possibleNames = {t.id, t.Id, t.Name, t.ItemName}
                                for _, v in ipairs(possibleNames) do
                                    if type(v) == "string" and string.len(v) > 2 and not isUUID(v) then
                                        return v
                                    end
                                end
                                
                                for _, v in pairs(t) do
                                    if type(v) == "table" then
                                        local res = getReadableName(v)
                                        if res then return res end
                                    end
                                end
                                return nil
                            end
                            
                            item = getReadableName(mailData) or tostring(mailData.ItemKey or mailData.Id or "Unknown Item")
                            count = tonumber(mailData.Amount or mailData.Count or mailData.Quantity or (mailData._data and mailData._data._am) or 1) or 1
                        end
                        
                        AddHistoryRecord(senderUid, senderName, item, count, "receive")
                        SendReceiveWebhookLog(senderUid, senderName, item, count)
                    end
                end
            end
            isFirstInboxCheck = false
        end
    end
end)

