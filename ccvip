-- DYNAMIC INVENTORY LOGIC
-- ==========================================
local ItemInputs = {}
local isRefreshing = false

local function RefreshInventoryUI()
    if isRefreshing then return end 
    isRefreshing = true
    
    local ok, replica = pcall(function() return PS:WaitForLocalReplica(1) end)
    if not (ok and replica and replica.Data and replica.Data.Inventory) then 
        isRefreshing = false
        return 
    end
    
    local inv = replica.Data.Inventory
    local trackedItems = {}
    for id, _ in pairs(ItemInputs) do trackedItems[id] = true end
    
    for category, items in pairs(inv) do
        for itemID, itemData in pairs(items) do
            trackedItems[itemID] = nil 
            local realName = itemID
            local count = 0
            
            if type(itemData) == "table" then
                realName = itemData.ItemKey or itemData.Name or itemData.Id or itemID
                count = itemData.Amount or 0
            else
                count = itemData
            end
            
            if count > 0 then
                if not ItemInputs[itemID] then
                    local Row = Instance.new("Frame", Scroll)
                    Row.Size = UDim2.new(1, -10, 0, 24)
                    Row.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                    Instance.new("UICorner", Row)

                    local NameLabel = Instance.new("TextLabel", Row)
                    NameLabel.Size = UDim2.new(0.5, 0, 1, 0)
                    NameLabel.Position = UDim2.new(0.05, 0, 0, 0)
                    NameLabel.Text = realName
                    NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                    NameLabel.TextXAlignment = Enum.TextXAlignment.Left
                    NameLabel.TextSize = 9
                    NameLabel.BackgroundTransparency = 1

                    local CountLabel = Instance.new("TextLabel", Row)
                    CountLabel.Size = UDim2.new(0.2, 0, 1, 0)
                    CountLabel.Position = UDim2.new(0.55, 0, 0, 0)
                    CountLabel.Text = "(" .. count .. ")"
                    CountLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
                    CountLabel.TextSize = 9
                    CountLabel.BackgroundTransparency = 1

                    local AmountInp = Instance.new("TextBox", Row)
                    AmountInp.Size = UDim2.new(0.2, 0, 0.8, 0)
                    AmountInp.Position = UDim2.new(0.75, 0, 0.1, 0)
                    AmountInp.Text = "0"
                    AmountInp.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
                    AmountInp.TextColor3 = Color3.fromRGB(0, 255, 127)
                    AmountInp.TextSize = 9
                    Instance.new("UICorner", AmountInp)

                    ItemInputs[itemID] = {UI = Row, Input = AmountInp, Label = CountLabel, Cat = category, Key = realName}
                else
                    ItemInputs[itemID].UI.Visible = true
                    ItemInputs[itemID].Label.Text = "(" .. count .. ")"
                end
            elseif ItemInputs[itemID] then
                ItemInputs[itemID].UI.Visible = false
                ItemInputs[itemID].Input.Text = "0"
            end
        end
    end
    
    for missingID, _ in pairs(trackedItems) do
        if ItemInputs[missingID] then
            ItemInputs[missingID].UI.Visible = false
            ItemInputs[missingID].Input.Text = "0"
        end
    end
    Scroll.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y)
    isRefreshing = false
end

