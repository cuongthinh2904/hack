    AvatarImg.Image = "rbxthumb://type=AvatarHeadShot&id=" .. tostring(entry.uid) .. "&w=48&h=48"
    local AvatarCorner = Instance.new("UICorner", AvatarImg)
    AvatarCorner.CornerRadius = UDim.new(1, 0)

    local TextLbl = Instance.new("TextLabel", EntryFrame)
    TextLbl.Size = UDim2.new(1, -34, 1, 0)
    TextLbl.Position = UDim2.new(0, 32, 0, 0)
    TextLbl.BackgroundTransparency = 1
    TextLbl.Font = Enum.Font.Gotham
    TextLbl.TextSize = 10
    TextLbl.TextXAlignment = Enum.TextXAlignment.Left
    TextLbl.TextWrapped = true -- Cho phép tự động xuống dòng
    
    local prefix = "To:"
    if entry.type == "receive" then
        prefix = "From:"
        EntryFrame.BackgroundColor3 = Color3.fromRGB(20, 45, 20)
        TextLbl.TextColor3 = Color3.fromRGB(100, 255, 100)
    elseif entry.type == "short" then
        prefix = "To:"
        EntryFrame.BackgroundColor3 = Color3.fromRGB(60, 15, 15)
        TextLbl.TextColor3 = Color3.fromRGB(255, 100, 100)
    else
        prefix = "To:"
        EntryFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        TextLbl.TextColor3 = Color3.fromRGB(220, 220, 220)
    end
    
    local timeStr = os.date("%H:%M", entry.time or os.time())
    local fullText = ""
    
    -- Format mới (amount rỗng vì đã gộp chuỗi vào item)
    if entry.amount == "" then
        fullText = string.format("%s %s [%s]\n%s", prefix, entry.name, timeStr, entry.item)
    else
        -- Hỗ trợ đọc lại file Lịch sử cũ
        local amtStr = tostring(entry.amount)
        if not string.match(amtStr, "x") and not string.match(amtStr, "/") then amtStr = "x" .. amtStr end
        fullText = string.format("%s %s [%s]\nItem: %s - %s", prefix, entry.name, timeStr, entry.item, amtStr)
    end
    
    TextLbl.Text = fullText
    
    -- Tự động co giãn chiều cao của bảng dựa trên độ dài chữ
    local textLen = string.len(fullText)
    local frameHeight = 32
    if textLen > 35 then
        frameHeight = 32 + math.ceil((textLen - 35) / 32) * 12
    end
    EntryFrame.Size = UDim2.new(1, 0, 0, frameHeight)
end

local function SyncHistoryUI()
    for _, child in ipairs(HistoryScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    local currentTime = os.time()
    local validHistory = {}
    for _, entry in ipairs(LocalHistory) do
        if (currentTime - entry.time) <= THREE_DAYS then
            table.insert(validHistory, entry)
            RenderHistoryEntry(entry)
        end
    end
    if #validHistory ~= #LocalHistory then
        LocalHistory = validHistory
        SaveHistoryToFile()
    end
end

