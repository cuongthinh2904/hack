-- ==========================================
-- DYNAMIC INVENTORY LOGIC (SMART PET GROUPING)
-- ==========================================
local ItemInputs = {}
local isRefreshing = false

local function isUUID(str)
    return type(str) == "string" and string.match(str, "%x%x%x%x%x%x%x%x%-") ~= nil
end

local function RefreshInventoryUI()
    if isRefreshing then return end 
    isRefreshing = true
    
    local ok, replica = pcall(function() return PS:WaitForLocalReplica(1) end)
    if not (ok and replica and replica.Data) then 
        isRefreshing = false
        return 
    end
    
    -- Gộp Inventory và Pets lại để quét chung
    local dictsToScan = {}
    if replica.Data.Inventory then dictsToScan.Inventory = replica.Data.Inventory end
    if replica.Data.Pets then dictsToScan.Pets = replica.Data.Pets end
    if replica.Data.Pet then dictsToScan.Pet = replica.Data.Pet end

    local AggregatedItems = {} -- [Tên hiển thị] = { Total = x, List = { uuid1, uuid2... } }

    for catName, invDict in pairs(dictsToScan) do
        for category, items in pairs(invDict) do
            -- Xử lý trường hợp Pets không có category con mà trải dài ra luôn
            local iterTable = (type(items) == "table" and not items.id and not items.ItemKey) and items or { [category] = items }
            local iterCat = (type(items) == "table" and not items.id and not items.ItemKey) and category or catName

            for itemID, itemData in pairs(iterTable) do
                local realName = itemID
                local count = 0
                local itemKeyForSend = itemID

                if type(itemData) == "table" then
                    -- Lấy tên thật (Bypass UUID)
                    if itemData._data and itemData._data.id and not isUUID(itemData._data.id) then
                        realName = tostring(itemData._data.id)
                    elseif itemData.id and not isUUID(itemData.id) then
                        realName = tostring(itemData.id)
                    elseif itemData.Name and not isUUID(itemData.Name) then
                        realName = tostring(itemData.Name)
                    else
                        realName = tostring(itemData.ItemKey or itemID)
                    end
                    
                    -- Lấy số lượng (Nếu là Pet không có Amount, tự ép count = 1)
                    local explicitAmount = tonumber(itemData.Amount or itemData._am or itemData.Count or itemData.Quantity)
                    if explicitAmount then
                        count = explicitAmount
                    else
                        count = 1 -- Pet riêng lẻ!
                    end
                    
                    itemKeyForSend = itemData.ItemKey or itemData.id or itemID
                else
                    count = tonumber(itemData) or 0
                end
                
                -- Gom nhóm vào AggregatedItems
                if count > 0 then
                    if not AggregatedItems[realName] then
                        AggregatedItems[realName] = { Total = 0, RawItems = {} }
                    end
                    AggregatedItems[realName].Total = AggregatedItems[realName].Total + count
                    table.insert(AggregatedItems[realName].RawItems, {
                        DictKey = itemID,
                        Category = iterCat,
                        ItemKey = itemKeyForSend,
                        Available = count
                    })
                end
            end
        end
    end
    
    -- Xóa UI cũ và Render UI mới theo nhóm
    local trackedNames = {}
    for name, _ in pairs(ItemInputs) do trackedNames[name] = true end
    
    for realName, data in pairs(AggregatedItems) do
        trackedNames[realName] = nil
        
        if not ItemInputs[realName] then
            local Row = Instance.new("Frame", Scroll)
            Row.Size = UDim2.new(1, -10, 0, 26)
            Row.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            Instance.new("UICorner", Row)

            local NameLabel = Instance.new("TextLabel", Row)
            NameLabel.Size = UDim2.new(0.5, 0, 1, 0)
            NameLabel.Position = UDim2.new(0.05, 0, 0, 0)
            NameLabel.Text = realName
            NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            NameLabel.TextXAlignment = Enum.TextXAlignment.Left
            NameLabel.TextSize = 10
            NameLabel.BackgroundTransparency = 1

            local CountLabel = Instance.new("TextLabel", Row)
            CountLabel.Size = UDim2.new(0.2, 0, 1, 0)
            CountLabel.Position = UDim2.new(0.55, 0, 0, 0)
            CountLabel.Text = "(" .. data.Total .. ")"
            CountLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            CountLabel.TextSize = 10
            CountLabel.BackgroundTransparency = 1

            local AmountInp = Instance.new("TextBox", Row)
            AmountInp.Size = UDim2.new(0.2, 0, 0.8, 0)
            AmountInp.Position = UDim2.new(0.75, 0, 0.1, 0)
            AmountInp.Text = "0"
            AmountInp.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            AmountInp.TextColor3 = Color3.fromRGB(0, 255, 127)
            AmountInp.TextSize = 10
            Instance.new("UICorner", AmountInp)

            ItemInputs[realName] = { UI = Row, Input = AmountInp, Label = CountLabel, RawItems = data.RawItems }
        else
            ItemInputs[realName].UI.Visible = true
            ItemInputs[realName].Label.Text = "(" .. data.Total .. ")"
            ItemInputs[realName].RawItems = data.RawItems -- Update the pointers
        end
    end
    
    -- Ẩn các món đồ đã hết
    for missingName, _ in pairs(trackedNames) do
        if ItemInputs[missingName] then
            ItemInputs[missingName].UI.Visible = false
            ItemInputs[missingName].Input.Text = "0"
            ItemInputs[missingName].RawItems = {}
        end
    end
    
    Scroll.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y)
    isRefreshing = false
end

