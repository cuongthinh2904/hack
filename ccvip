    task.spawn(function() task.wait(0.5); RefreshInventoryUI() end)
    ClaimAllBtn.Active = true
end

local function SendMailBatch()
    local targetName = UserInput.Text
    if targetName == "" then StatusLabel.Text = "Nhập Username!" return end
    
    StartBtn.Active = false
    StatusLabel.Text = "Tìm UID..."
    
    local ok, uid = pcall(function() 
        local res = Net.Mailbox.LookupPlayer:Fire(targetName) 
        if type(res) == "table" and res.Get then return res:Get() end
        return res
    end)
    
    if not ok or type(uid) ~= "number" or uid <= 0 then
        StatusLabel.Text = "LỖI: Không thấy user!"
        StartBtn.Active = true
        return
    end
    
    local plan = {}
    local sendLogs = {}
    
    for hash, data in pairs(ItemInputs) do
        local requestedVal = math.floor(tonumber(data.Input.Text) or 0)
        
        if requestedVal > 0 then
            local currentTotal = tonumber(string.match(data.Label.Text, "%d+")) or 0
            local actuallySent = math.min(requestedVal, currentTotal)
            local missingAmount = requestedVal - actuallySent
            
            if actuallySent > 0 then
                table.insert(sendLogs, { Name = data.DisplayName, Sent = actuallySent, Missing = missingAmount, Before = currentTotal })
                
                local remaining = actuallySent
                for _, rawItem in ipairs(data.RawItems) do
                    if remaining <= 0 then break end
                    local takeAmount = math.min(remaining, rawItem.Available)
                    
                    table.insert(plan, {
                        DictKey = rawItem.DictKey, 
                        Category = rawItem.Category, 
                        ItemKey = rawItem.ItemKey, 
                        Count = takeAmount
                    })
                    remaining = remaining - takeAmount
                end
            end
        end
    end
    
    if #plan == 0 then StatusLabel.Text = "Chưa nhập số lượng hợp lệ!" StartBtn.Active = true return end
    
    local sendSuccess = true
    
    for i = 1, #plan, 20 do
        local batch = {}
        for j = i, math.min(i + 19, #plan) do table.insert(batch, {Category = plan[j].Category, ItemKey = plan[j].ItemKey, Count = plan[j].Count}) end
        
        StatusLabel.Text = "Gửi đợt " .. math.ceil(i/20)
        local checkCat = plan[i].Category
        local checkDictKey = plan[i].DictKey
        
        local oldAmount = 0
        pcall(function()
            local rep = PS:WaitForLocalReplica(1)
            local itemData = rep.Data.Inventory and rep.Data.Inventory[checkCat] and rep.Data.Inventory[checkCat][checkDictKey]
            if not itemData then itemData = rep.Data.Pets and rep.Data.Pets[checkCat] and rep.Data.Pets[checkCat][checkDictKey] end
            if not itemData then itemData = rep.Data.Pets and rep.Data.Pets[checkDictKey] end
            
            if type(itemData) == "table" then oldAmount = tonumber(itemData.Amount or itemData._am or 1)
            else oldAmount = tonumber(itemData) or 1 end
        end)
        
        local batchOk = pcall(function() 
            local res = Net.Mailbox.SendBatch:Fire(uid, batch, "GIFT VIP CTHINH V1.17") 
            if type(res) == "table" and res.Wait then res:Wait() end
        end)
        
        task.wait(1.5)
        
        local currentAmount = 0
        pcall(function()
            local rep = PS:WaitForLocalReplica(1)
            local itemData = rep.Data.Inventory and rep.Data.Inventory[checkCat] and rep.Data.Inventory[checkCat][checkDictKey]
            if not itemData then itemData = rep.Data.Pets and rep.Data.Pets[checkCat] and rep.Data.Pets[checkCat][checkDictKey] end
            if not itemData then itemData = rep.Data.Pets and rep.Data.Pets[checkDictKey] end
            
            if itemData then
                if type(itemData) == "table" then currentAmount = tonumber(itemData.Amount or itemData._am or 1)
                else currentAmount = tonumber(itemData) or 1 end
            end
        end)
        
        if not batchOk or currentAmount >= oldAmount then
            sendSuccess = false
            StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            StatusLabel.Text = "LỖI: Hết lượt (Limit 50)!"
            break
        end
        task.wait(1)
    end
    
    if sendSuccess then
        StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        
        local webhookLines = {}
        local displayStrings = {}
        local isAnyShort = false

        -- GOM NHÓM LẠI CHO ĐẸP KHI GỬI
        for _, logData in ipairs(sendLogs) do
            local afterCount = logData.Before - logData.Sent
            if afterCount < 0 then afterCount = 0 end
            
            if logData.Missing > 0 then
                isAnyShort = true
                table.insert(displayStrings, string.format("%s %d/%d", logData.Name, logData.Sent, logData.Sent + logData.Missing))
                table.insert(webhookLines, string.format("📦 **Item:** %s | 🔢 **Amount:** %d/%d | 📉 **Stock:** %d ➔ %d", logData.Name, logData.Sent, logData.Sent + logData.Missing, logData.Before, afterCount))
            else
                table.insert(displayStrings, string.format("%s x%d", logData.Name, logData.Sent))
                table.insert(webhookLines, string.format("📦 **Item:** %s | 🔢 **Amount:** x%d | 📉 **Stock:** %d ➔ %d", logData.Name, logData.Sent, logData.Before, afterCount))
            end
        end
        
        local combinedDisplay = table.concat(displayStrings, ", ")
        local webhookDesc = string.format("👤 **To:** `%s`\n\n%s", targetName, table.concat(webhookLines, "\n"))
        
        AddHistoryRecord(uid, targetName, "Items: " .. combinedDisplay, "", isAnyShort and "short" or "send")
        SendWebhookLog(uid, targetName, webhookDesc, isAnyShort)
        
        for _, data in pairs(ItemInputs) do data.Input.Text = "0" end
        UserInput.Text = ""
        StatusLabel.Text = "✅ GỬI THÀNH CÔNG!"
        
        task.spawn(function() task.wait(0.5); RefreshInventoryUI() end)
    end
    StartBtn.Active = true
end

